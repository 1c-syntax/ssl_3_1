	Результат.ДлительностьТекущегоСерверногоВызова = Сеанс.ДлительностьВызововТекущее;
	Результат.ДлительностьСерверныхВызововЗа5Минут = Сеанс.ДлительностьВызововЗа5Мин;
	Результат.ПереданоСУБД = Сеанс.ОбъемДанныхПереданныхИПолученныхСУБДВсего;
	Результат.ПереданоСУБДЗа5Минут = Сеанс.ОбъемДанныхПереданныхИПолученныхСУБДЗа5Мин;
	Результат.ДлительностьВызововСУБД = Сеанс.ДлительностьВызововСУБДВсего;
	Результат.ДлительностьТекущегоВызоваСУБД = Сеанс.ДлительностьВызововСУБДТекущее;
	Результат.ДлительностьВызововСУБДЗа5Минут = Сеанс.ДлительностьВызововСУБДЗа5Мин;
	Результат.СоединениеСУБД = Сеанс.СоединениеСУБД;

	Результат.Спящий = Сеанс.СпящийСеанс;
	Результат.ЗавершитьЧерез = Сеанс.ВремяЗавершенияСпящегоСеанса;
	Результат.ЗаснутьЧерез = Сеанс.ВремяЗасыпанияПассивногоСеанса;
	Результат.ПрочитаноСДиска = Сеанс.ОбъемДанныхСчитанныхСДискаВсего;
	Результат.ПрочитаноСДискаВТекущемВызове = Сеанс.ОбъемДанныхСчитанныхСДискаТекущее;
	Результат.ПрочитаноСДискаЗа5Минут = Сеанс.ОбъемДанныхСчитанныхСДискаЗа5Минут;
	Результат.ЗанятоПамяти = Сеанс.ПотреблениеПамятиВсего;
	Результат.ЗанятоПамятиВТекущемВызове = Сеанс.ПотреблениеПамятиТекущее;
	Результат.ЗанятоПамятиЗа5Минут = Сеанс.ПотреблениеПамятиЗа5Мин;
	Результат.ЗаписаноНаДиск = Сеанс.ОбъемДанныхЗаписанныхНаДискВсего;
	Результат.ЗаписаноНаДискВТекущемВызове = Сеанс.ОбъемДанныхЗаписанныхНаДискТекущее;
	Результат.ЗаписаноНаДискЗа5Минут = Сеанс.ОбъемДанныхЗаписанныхНаДискЗа5Мин;
	
	Результат.ВремяСоединенияСУБД = 0;
	Результат.МоментЗахватаСоединенияСУБД = "";
	
	Возврат Результат;
КонецФункции

Функция ОписаниеЛицензии(Лицензия)	
	Результат = АдминистрированиеКластера.СвойстваЛицензии();
	ЗаполнитьЗначенияСвойств(Результат, Лицензия);
	Результат.ВыданаСервером = Лицензия.ПолученаСервером;
	Результат.ТипЛицензии = Лицензия.ПрограммнаяЛицензия;
	Результат.МаксимальноеКоличествоПользователейДляКомплекта = Лицензия.МаксимальноеКоличествоПользователейПрограммнойЛицензии;
	Результат.МаксимальноеКоличествоПользователейВКлюче = Лицензия.МаксимальноеКоличествоПользователей;
	Результат.ЛицензияПолученаЧерезAladdinLicenseManager = Лицензия.СетевойКлюч;
	Результат.АдресПроцесса = Лицензия.АдресСервера;
	Результат.ПортПроцесса = Лицензия.ПортСервера;
	Результат.ПолноеПредставление = Лицензия.ПодробноеПредставление;
	Результат.ТипЛицензии = ?(Лицензия.ПрограммнаяЛицензия, 0, 1);
	Возврат Результат;
КонецФункции

