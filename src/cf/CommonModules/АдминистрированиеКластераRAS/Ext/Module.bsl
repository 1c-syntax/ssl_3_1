	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	Возврат БазаКластера.ПрофильБезопасности;
КонецФункции

// См. АдминистрированиеКластера.ПрофильБезопасностиБезопасногоРежимаИнформационнойБазы
Функция ПрофильБезопасностиБезопасногоРежимаИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ) Экспорт
