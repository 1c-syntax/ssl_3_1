Функция АгентСервера(ПараметрыАдминистрированияКластера)
	
	АдресСервераАдминистрирования = ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования;
	ПортСервераАдминистрирования = ПараметрыАдминистрированияКластера.ПортСервераАдминистрирования;
	Результат = Новый АдминистрированиеСервера(АдресСервераАдминистрирования, ПортСервераАдминистрирования);

	Возврат Результат;

КонецФункции

Функция КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера)
	Результат = Неопределено;
	
	ПортКластера = ПараметрыАдминистрированияКластера.ПортКластера;

	Кластеры = АгентСервера.ПолучитьКластеры();
	Для Каждого Кластер Из Кластеры Цикл
		Если Кластер.Порт = ПортКластера Тогда
			Результат = Кластер;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Результат = Неопределено Тогда
		ШаблонИсключения = НСтр("ru = 'На сервере администрирования %1 не найден кластер на порту %2'");
		ПортКластераФормат = Формат(ПортКластера, "ЧГ=;");
		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонИсключения, ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования, ПортКластераФормат);
		ВызватьИсключение ТекстИсключения;
	Иначе
		ИмяАдминистратораКластера = ПараметрыАдминистрированияКластера.ИмяАдминистратораКластера;
		ПарольАдминистратораКластера = ПараметрыАдминистрированияКластера.ПарольАдминистратораКластера;
		
		Результат.ВыполнитьАутентификацию(ИмяАдминистратораКластера, ПарольАдминистратораКластера);
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

Функция БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ)
	Результат = Неопределено;
		
	ИнформационныеБазы = КластерСервера.ПолучитьИнформационныеБазы();
	Для Каждого ИнформационнаяБаза Из ИнформационныеБазы Цикл
		Если ИнформационнаяБаза.Имя = ПараметрыАдминистрированияИБ.ИмяВКластере Тогда
			Результат = ИнформационнаяБаза;
			Прервать;
		КонецЕсли;
	КонецЦикла;
	
	Если Результат = Неопределено Тогда
		ШаблонИсключения = НСтр("ru = 'В кластере серверов %1:%2 не найдена информационная база ""%3""'");
		ПортКластераФормат = Формат(КластерСервера.Порт, "ЧГ=;");
		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонИсключения, КластерСервера.ИмяКомпьютера,
			ПортКластераФормат, ПараметрыАдминистрированияИБ.ИмяВКластере);
		ВызватьИсключение ТекстИсключения;
	Иначе
		ИмяАдминистратораИнформационнойБазы = ПараметрыАдминистрированияИБ.ИмяАдминистратораИнформационнойБазы;	
		ПарольАдминистратораИнформационнойБазы = ПараметрыАдминистрированияИБ.ПарольАдминистратораИнформационнойБазы;
		Результат.ВыполнитьАутентификацию(ИмяАдминистратораИнформационнойБазы, ПарольАдминистратораИнформационнойБазы);
	КонецЕсли;	
	
	Возврат Результат;
КонецФункции

Функция СвойстваСеансовИзОписанияБлокировок(КластерСервера, БазаКластера)
	Результат = Новый Соответствие();
	Блокировки = КластерСервера.ПолучитьБлокировки();
	Для Каждого Блокировка Из Блокировки Цикл			
		Если ЗначениеЗаполнено(Блокировка.ИдентификаторСеанса) Тогда
			АдминистрированиеКластера.ДанныеСеансаИзБлокировки(Результат,
				Блокировка.Описание,
				Блокировка.ИдентификаторСеанса,
				БазаКластера.Name);
		КонецЕсли;
	КонецЦикла;

	Возврат Результат;
КонецФункции

Функция СписокСеансов(АгентСервера, КластерСервера, БазаКластера, Знач Фильтр = Неопределено, ДобавитьОбъектСеанса = Ложь)
	Результат = Новый Массив;

	СвойстваСеансовИзОписанияБлокировок = СвойстваСеансовИзОписанияБлокировок(КластерСервера, БазаКластера);

	СеансыБазы = БазаКластера.ПолучитьСеансы();
	СоединенияБазы = БазаКластера.ПолучитьСоединения();
	РабочиеПроцессыКластера = КластерСервера.ПолучитьРабочиеПроцессы();
	Для Каждого Сеанс Из СеансыБазы Цикл
		ОписаниеСеанса = ОписаниеСеанса(Сеанс);
		Если ЗначениеЗаполнено(Сеанс.Лицензии) Тогда
			ЛицензияСеанса = Сеанс.Лицензии[0]; // АдминистрированиеЛицензия
			ОписаниеСеанса.Лицензия = ОписаниеЛицензии(ЛицензияСеанса);
		КонецЕсли;
		
		СвойстваСеансаИзБлокировки = СвойстваСеансовИзОписанияБлокировок[Сеанс.ИдентификаторСеанса];		
		Если ЗначениеЗаполнено(СвойстваСеансаИзБлокировки) Тогда
			ОписаниеСеанса.Разделитель = СвойстваСеансаИзБлокировки.Разделитель;
			ОписаниеСеанса.РежимБлокировкиБД = СвойстваСеансаИзБлокировки.РежимБлокировкиБД;
		КонецЕсли;

		СоединениеСеанса = СоединениеСеанса(Сеанс, СоединенияБазы);
		Если СоединениеСеанса <> Неопределено Тогда
			ОписаниеСеанса.ОписаниеСоединения = ОписаниеСоединения(СоединениеСеанса);
			РабочийПроцессСеанса = РабочийПроцессСеанса(СоединениеСеанса, РабочиеПроцессыКластера);	
			Если РабочийПроцессСеанса <> Неопределено Тогда
				ОписаниеРабочегоПроцесса = ОписаниеРабочегоПроцесса(РабочийПроцессСеанса, КластерСервера);
				
				ОписаниеСеанса.РабочийПроцесс = ОписаниеРабочегоПроцесса;
				ОписаниеСеанса.ОписаниеСоединения.РабочийПроцесс = ОписаниеРабочегоПроцесса;
			КонецЕсли;
		КонецЕсли;

		Если АдминистрированиеКластера.ПроверитьУсловияФильтра(ОписаниеСеанса, Фильтр) Тогда
			Если ДобавитьОбъектСеанса Тогда
				ОписаниеСеанса.Вставить("ОбъектСеанса", Сеанс);
			КонецЕсли;
			Результат.Добавить(ОписаниеСеанса);
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СоединениеСеанса(Сеанс, СоединенияБазы)
	Перем Результат;
	Для Каждого Соединение Из СоединенияБазы Цикл
		Если Соединение.ИдентификаторСоединения = Сеанс.ИдентификаторСоединения Тогда
			Результат = Соединение;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	Возврат Результат;
КонецФункции

Функция РабочийПроцессСеанса(СоединениеСеанса, РабочиеПроцессыКластера)
	Перем Результат;
	Для Каждого РабочийПроцесс Из РабочиеПроцессыКластера Цикл
		Если СоединениеСеанса.ИдентификаторПроцесса = РабочийПроцесс.ИдентификаторРабочегоПроцесса Тогда
			Результат = РабочийПроцесс;					
			Прервать;
		КонецЕсли;	
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция СписокСоединений(АгентСервера, КластерСервера, БазаКластера, Знач Фильтр = Неопределено, Описания = Ложь)
	Результат = Новый Массив();
	Для каждого Соединение Из БазаКластера.ПолучитьСоединения() Цикл
		ОписаниеСоединения = ОписаниеСоединения(Соединение);
		Если Не ЗначениеЗаполнено(ОписаниеСоединения.Номер) Тогда
			Продолжить;
		КонецЕсли;

		Если АдминистрированиеКластера.ПроверитьУсловияФильтра(ОписаниеСоединения, Фильтр) Тогда
			Если Описания Тогда
				Результат.Добавить(ОписаниеСоединения);
			Иначе
				Результат.Добавить(Соединение);
			КонецЕсли;
		КонецЕсли;
	КонецЦикла;
	Возврат Результат;
КонецФункции

Функция ОбъектПрофиляБезопасности(ПараметрыАдминистрированияКластера, ИмяПрофиля)
	Результат = Неопределено;
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	ПрофилиБезопасности = КластерСервера.ПолучитьПрофилиБезопасности();
	Для Каждого ПрофильБезопасности Из ПрофилиБезопасности Цикл
		Если ПрофильБезопасности.Имя = ИмяПрофиля Тогда
			Результат = ПрофильБезопасности;
			Прервать;
		КонецЕсли;
	КонецЦикла;	
	Возврат Результат;
КонецФункции

