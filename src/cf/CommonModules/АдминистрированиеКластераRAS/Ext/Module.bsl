// См. АдминистрированиеКластера.УстановитьПрофильБезопасностиИнформационнойБазы
Процедура УстановитьПрофильБезопасностиИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач ИмяПрофиля = "") Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	БазаКластера.ПрофильБезопасности = ИмяПрофиля;
	БазаКластера.Записать();
КонецПроцедуры

// См. АдминистрированиеКластера.УстановитьПрофильБезопасностиБезопасногоРежимаИнформационнойБазы
Процедура УстановитьПрофильБезопасностиБезопасногоРежимаИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач ИмяПрофиля = "") Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	БазаКластера.ПрофильБезопасностиБезопасногоРежима = ИмяПрофиля;
	БазаКластера.Записать();
КонецПроцедуры

// См. АдминистрированиеКластера.ПрофильБезопасностиСуществует
Функция ПрофильБезопасностиСуществует(Знач ПараметрыАдминистрированияКластера, Знач ИмяПрофиля) Экспорт
	ОбъектПрофиляБезопасности = ОбъектПрофиляБезопасности(ПараметрыАдминистрированияКластера, ИмяПрофиля);
	Результат = ОбъектПрофиляБезопасности <> Неопределено;
	Возврат Результат;
КонецФункции

// См. АдминистрированиеКластера.ПрофильБезопасности
Функция ПрофильБезопасности(Знач ПараметрыАдминистрированияКластера, Знач ИмяПрофиля) Экспорт
	Результат = АдминистрированиеКластера.СвойстваПрофиляБезопасности();
	ОбъектПрофиляБезопасности = ОбъектПрофиляБезопасности(ПараметрыАдминистрированияКластера, ИмяПрофиля);
	ЗаполнитьЗначенияСвойств(Результат, ОбъектПрофиляБезопасности);
	Результат.ПолныйДоступКПривилегированномуРежиму = ОбъектПрофиляБезопасности.ПолныйПривилегированныйРежим;
	Результат.ПолныйДоступКФункциямКриптографии = ОбъектПрофиляБезопасности.ДоступККриптографии;
	
	Результат.ПолныйДоступКРасширениюВсехМодулей = НЕ ЗначениеЗаполнено(Результат.ДоступныеДляРасширенияМодули)
		И НЕ ЗначениеЗаполнено(Результат.НедоступныеДляРасширенияМодули);
	Результат.ПолныйДоступКРасширениюПравДоступа = ОбъектПрофиляБезопасности.РазрешитьРасширениеПравДоступа;
	Результат.ПолныйДоступКПриложениямОперационнойСистемы = ОбъектПрофиляБезопасности.ПолныйДоступКВнешнимПриложениям;
	
	Результат.ВиртуальныеКаталоги = СвойстваВиртуальныхКаталогов(ОбъектПрофиляБезопасности);
	Результат.COMКлассы = СвойстваCOMКлассов(ОбъектПрофиляБезопасности);
	Результат.ВнешниеКомпоненты = СвойстваВнешнихКомпонент(ОбъектПрофиляБезопасности);
	Результат.ВнешниеМодули = СвойстваВнешнихМодулей(ОбъектПрофиляБезопасности);
	Результат.ПриложенияОС = СвойстваПриложенийОС(ОбъектПрофиляБезопасности);
	Результат.ИнтернетРесурсы = СвойстваИнтернетРесурсов(ОбъектПрофиляБезопасности);
	Возврат Результат;	
КонецФункции

// См. АдминистрированиеКластера.СоздатьПрофильБезопасности
Процедура СоздатьПрофильБезопасности(Знач ПараметрыАдминистрированияКластера, Знач СвойстваПрофиляБезопасности) Экспорт
	Если ПрофильБезопасностиСуществует(ПараметрыАдминистрированияКластера, СвойстваПрофиляБезопасности.Имя) Тогда
		ПредставлениеКластера = СтрШаблон("%1:%2", 
			ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования,
			Формат(ПараметрыАдминистрированияКластера.ПортКластера, "ЧГ=;"));
		ШаблонИсключения = НСтр("ru = 'В кластере серверов %1 уже зарегистрирован профиль безопасности %2'");
		ТекстИсключения = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(ШаблонИсключения, ПредставлениеКластера, СвойстваПрофиляБезопасности.Имя);
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	ОбъектПрофиля = КластерСервера.СоздатьПрофильБезопасности();
		
	ЗагрузитьСвойстваПрофиляБезопасности(ОбъектПрофиля, СвойстваПрофиляБезопасности);	
КонецПроцедуры

// См. АдминистрированиеКластера.УстановитьСвойстваПрофиляБезопасности
Процедура УстановитьСвойстваПрофиляБезопасности(Знач ПараметрыАдминистрированияКластера, Знач СвойстваПрофиляБезопасности)  Экспорт
	ОбъектПрофиля = ОбъектПрофиляБезопасности(ПараметрыАдминистрированияКластера, СвойстваПрофиляБезопасности.Имя);
	ЗагрузитьСвойстваПрофиляБезопасности(ОбъектПрофиля, СвойстваПрофиляБезопасности);
КонецПроцедуры

// См. АдминистрированиеКластера.УдалитьПрофильБезопасности
Процедура УдалитьПрофильБезопасности(Знач ПараметрыАдминистрированияКластера, Знач ИмяПрофиля) Экспорт
	ОбъектПрофиля = ОбъектПрофиляБезопасности(ПараметрыАдминистрированияКластера, ИмяПрофиля);
	Если ОбъектПрофиля <> Неопределено Тогда
		ОбъектПрофиля.Удалить();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область ИнформационныеБазы

// См. АдминистрированиеКластера.ИдентификаторИнформационнойБазы
Функция ИдентификаторИнформационнойБазы(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИнформационнойБазы) Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИнформационнойБазы);
	Возврат БазаКластера.ИдентификаторИнформационнойБазы;
КонецФункции

// См. АдминистрированиеКластера.СвойстваИнформационныхБаз
Функция СвойстваИнформационныхБаз(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач Фильтр = Неопределено) Экспорт
	Команда = "infobase summary list " + ПараметрыКластера(ПараметрыАдминистрированияКластера, ИдентификаторКластера);
	ТипыСвойствОписанияБазы = ТипыСвойствОписанияБазы();
	Свойства = ЗапуститьКоманду(Команда, ПараметрыАдминистрированияКластера, , Фильтр, ТипыСвойствОписанияБазы);
	
	Возврат Свойства;
КонецФункции

#КонецОбласти

#Область Кластер

// См. АдминистрированиеКластера.ИдентификаторКластера
Функция ИдентификаторКластера(Знач ПараметрыАдминистрированияКластера) Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	Возврат КластерСервера.ИдентификаторКластера;
КонецФункции

// См. АдминистрированиеКластера.СвойстваКластеров
Функция СвойстваКластеров(Знач ПараметрыАдминистрированияКластера, Знач Фильтр = Неопределено) Экспорт
	Если ЗначениеЗаполнено(ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования) Тогда
		Сервер = СокрЛП(ПараметрыАдминистрированияКластера.АдресСервераАдминистрирования);
		Если ЗначениеЗаполнено(ПараметрыАдминистрированияКластера.ПортСервераАдминистрирования) Тогда
			Сервер = Сервер + ":" + ПривестиЗначение(ПараметрыАдминистрированияКластера.ПортСервераАдминистрирования);
		КонецЕсли;
	Иначе
		Сервер = "";
	КонецЕсли;
	ТипыСвойствКластера = ТипыСвойствКластера();
	Результат = ЗапуститьКоманду("cluster list " + Сервер, ПараметрыАдминистрированияКластера, , Фильтр, ТипыСвойствКластера);
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область РабочиеПроцессыСерверы

// См. АдминистрированиеКластера.СвойстваРабочихПроцессов
Функция СвойстваРабочихПроцессов(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач Фильтр = Неопределено) Экспорт
	ПараметрыКластера = ПараметрыКластера(ПараметрыАдминистрированияКластера, ИдентификаторКластера);
	Результат = ЗапуститьКоманду("process list " + ПараметрыКластера, ПараметрыАдминистрированияКластера, , Фильтр);
	Возврат Результат;
КонецФункции

// См. АдминистрированиеКластера.СвойстваРабочихСерверов
Функция СвойстваРабочихСерверов(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач Фильтр = Неопределено) Экспорт
	ПараметрыКластера = ПараметрыКластера(ПараметрыАдминистрированияКластера, ИдентификаторКластера);
	ТипыСвойствРабочихСерверов = ТипыСвойствРабочихСерверов();
	Результат = ЗапуститьКоманду("server list " + ПараметрыКластера, ПараметрыАдминистрированияКластера, , Фильтр, ТипыСвойствРабочихСерверов);
	Возврат Результат;
КонецФункции

#КонецОбласти

// См. АдминистрированиеКластера.СвойстваСеансов
Функция СвойстваСеансов(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач ИдентификаторИнформационнойБазы, Знач Фильтр = Неопределено, Знач ИспользоватьСловарь = Истина) Экспорт
	
	Команда = "session list --infobase=%1 " + ПараметрыКластера(ПараметрыАдминистрированияКластера, ИдентификаторКластера);	
	ПодставитьПараметрыВКоманду(Команда, ИдентификаторИнформационнойБазы);	
	
	Если ИспользоватьСловарь Тогда
		Словарь = СловарьСвойствСеансов();
	Иначе
		Словарь = Неопределено;
		Фильтр = ФильтрВНотациюRac(Фильтр, СловарьСвойствСеансов());
	КонецЕсли;
	
	Результат = ЗапуститьКоманду(Команда, ПараметрыАдминистрированияКластера, Словарь, Фильтр, ТипыСвойствСеансов());
	
	Возврат Результат;                                       
	
КонецФункции

// См. АдминистрированиеКластера.СвойстваСоединений
Функция СвойстваСоединений(Знач ИдентификаторКластера, Знач ПараметрыАдминистрированияКластера, Знач ИдентификаторИнформационнойБазы, Знач ПараметрыАдминистрированияИнформационнойБазы, Знач Фильтр = Неопределено, Знач ИспользоватьСловарь = Ложь) Экспорт
	
	ПараметрыКластера = ПараметрыКластера(ПараметрыАдминистрированияКластера, ИдентификаторКластера);
	
	Если ИспользоватьСловарь Тогда
		Словарь = СловарьСвойствСоединений();
	Иначе
		Словарь = Неопределено;
		Фильтр = ФильтрВНотациюRac(Фильтр, СловарьСвойствСоединений());
	КонецЕсли;
	
	Результат = Новый Массив();
	РабочиеПроцессы = СвойстваРабочихПроцессов(ИдентификаторКластера, ПараметрыАдминистрированияКластера);
	
	Для Каждого РабочийПроцесс Из РабочиеПроцессы Цикл
		
		Команда = "connection list --process=%1 --infobase=%2 --infobase-user=%3 --infobase-pwd=%4 " + ПараметрыКластера;
		ПодставитьПараметрыВКоманду(Команда,
			РабочийПроцесс.Получить("process"),
			ИдентификаторИнформационнойБазы,
			ПараметрыАдминистрированияИнформационнойБазы.ИмяАдминистратораИнформационнойБазы,
			ПараметрыАдминистрированияИнформационнойБазы.ПарольАдминистратораИнформационнойБазы);
			
		СоединенияРабочегоПроцесса = ЗапуститьКоманду(Команда, ПараметрыАдминистрированияКластера, Словарь, Фильтр, ТипыСвойствСоединений());
		Для Каждого Соединение Из СоединенияРабочегоПроцесса Цикл
			Если ИспользоватьСловарь Тогда
				Если Соединение.РежимСоединенияСБазойДанных = "none" Тогда
					Соединение.Вставить("РежимСоединенияСБазойДанных", 0);
				ИначеЕсли Соединение.РежимСоединенияСБазойДанных = "shared" Тогда
					Соединение.Вставить("РежимСоединенияСБазойДанных", 1);
				Иначе // exclusive
					Соединение.Вставить("РежимСоединенияСБазойДанных", 2);
				КонецЕсли;
				Соединение.Вставить("РежимСоединенияСИнформационнойБазой", ?(Соединение.РежимСоединенияСИнформационнойБазой = "shared", 0, 1));
				Соединение.Вставить("УправлениеНаходитсяНаСервере", ?(Соединение.УправлениеНаходитсяНаСервере = "client", 0, 1));
			Иначе
				Соединение.Вставить("process", РабочийПроцесс.Получить("process"));
			КонецЕсли;
			Результат.Добавить(Соединение);
		КонецЦикла;
		
	КонецЦикла;
	
	Возврат Результат;
	
КонецФункции

// См. АдминистрированиеКластера.ПутьККлиентуСервераАдминистрирования
Функция ПутьККлиентуСервераАдминистрирования() Экспорт	
	КаталогЗапуска = ОбщегоНазначенияКлиентСервер.ДобавитьКонечныйРазделительПути(КаталогПрограммы());
	Результат = КаталогЗапуска + "rac";
	
	Если ОбщегоНазначения.ЭтоWindowsСервер() Тогда
		Результат = Результат + ".exe";
	КонецЕсли;
	
	Возврат Результат;
КонецФункции

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

#Область Сервис

Процедура УстановитьУмолчание(Приемник, ЗначениеКУстановке)
	Если НЕ ЗначениеЗаполнено(Приемник) Тогда
		Приемник = ЗначениеКУстановке;
	КонецЕсли;
КонецПроцедуры

Процедура УстановитьСвойство(Приемник, Источник, КлючИсточника)
	Перем ЗначениеСвойства;
	Если НЕ Источник.Свойство(КлючИсточника, ЗначениеСвойства) Тогда
		Возврат;
	КонецЕсли;	
	Если Приемник <> ЗначениеСвойства Тогда
		Приемник = ЗначениеСвойства;
	КонецЕсли;
КонецПроцедуры

Процедура Пауза(КоличествоСекунд)
	ОбновлениеИнформационнойБазыСлужебный.Пауза(КоличествоСекунд);
КонецПроцедуры

Процедура ЗаписатьОшибкуВЖурналРегистрации(Комментарий)
	ИмяСобытияЖР = НСтр("ru = 'Администрирование кластера'", ОбщегоНазначения.КодОсновногоЯзыка());
	ЗаписьЖурналаРегистрации(ИмяСобытияЖР, УровеньЖурналаРегистрации.Ошибка, , , Комментарий);
КонецПроцедуры

#КонецОбласти

#Область СоздатьПрофильБезопасности

Процедура ЗагрузитьСвойстваПрофиляБезопасности(ОбъектПрофиля, СвойстваПрофиляБезопасности)
	Если НЕ ЗначениеЗаполнено(ОбъектПрофиля.Имя) Тогда
		ОбъектПрофиля.Имя = СвойстваПрофиляБезопасности.Имя;
	КонецЕсли;
	ЗаполнитьЗначенияСвойств(ОбъектПрофиля, СвойстваПрофиляБезопасности, , "Имя");
	ОбъектПрофиля.ДоступККриптографии = СвойстваПрофиляБезопасности.ПолныйДоступКФункциямКриптографии;
	ОбъектПрофиля.ПолныйДоступКВнешнимПриложениям = СвойстваПрофиляБезопасности.ПолныйДоступКПриложениямОперационнойСистемы;
	ОбъектПрофиля.ПолныйПривилегированныйРежим = СвойстваПрофиляБезопасности.ПолныйДоступКПривилегированномуРежиму;
	ОбъектПрофиля.РазрешитьРасширениеПравДоступа = СвойстваПрофиляБезопасности.ПолныйДоступКРасширениюПравДоступа;
	ОбъектПрофиля.Записать();
	
	ЗагрузитьСвойстваВиртуальныхКаталогов(ОбъектПрофиля, СвойстваПрофиляБезопасности);
	ЗагрузитьСвойстваCOMКлассов(ОбъектПрофиля, СвойстваПрофиляБезопасности);
	ЗагрузитьСвойстваВнешнихКомпонент(ОбъектПрофиля, СвойстваПрофиляБезопасности);
	ЗагрузитьСвойстваВнешнихМодулей(ОбъектПрофиля, СвойстваПрофиляБезопасности);
	ЗагрузитьСвойстваПриложенийОС(ОбъектПрофиля, СвойстваПрофиляБезопасности);
	ЗагрузитьСвойстваИнтернетРесурсов(ОбъектПрофиля, СвойстваПрофиляБезопасности);
КонецПроцедуры

Процедура ОчиститьЭлементыСпискаКонтроляДоступа(ЭлементыСписка)
	Для Каждого Элемент Из ЭлементыСписка Цикл
		Элемент.Удалить();
	КонецЦикла;
КонецПроцедуры

Процедура ЗагрузитьСвойстваВиртуальныхКаталогов(ОбъектПрофиля, СвойстваПрофиляБезопасности)
	ТекущиеЗначения = ОбъектПрофиля.ПолучитьРазрешенныеВиртуальныеКаталоги();
	ОчиститьЭлементыСпискаКонтроляДоступа(ТекущиеЗначения);

	Для Каждого Источник Из СвойстваПрофиляБезопасности.ВиртуальныеКаталоги Цикл
		Приемник = ОбъектПрофиля.СоздатьРазрешенныйВиртуальныйКаталог();
		ЗаполнитьЗначенияСвойств(Приемник, Источник);
		Приемник.ЗаписьРазрешена = Источник.ЗаписьДанных;
		Приемник.ЧтениеРазрешено = Источник.ЧтениеДанных;
		Приемник.Путь = Источник.ФизическийURL;
		Приемник.Псевдоним = Источник.ЛогическийURL;
