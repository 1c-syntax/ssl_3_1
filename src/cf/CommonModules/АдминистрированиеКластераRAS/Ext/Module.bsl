#Область СлужебныйПрограммныйИнтерфейс

#Область БлокировкаСеансовИЗаданий

// См. АдминистрированиеКластера.БлокировкаСеансовИЗаданийИнформационнойБазы
Функция БлокировкаСеансовИЗаданийИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ) Экспорт
	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	Результат = СвойстваБлокировкиСеансовИРегламентныхЗаданий(БазаКластера);
	Возврат Результат;
	
КонецФункции

// См. АдминистрированиеКластера.УстановитьБлокировкуСеансовИЗаданийИнформационнойБазы
Процедура УстановитьБлокировкуСеансовИЗаданийИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач СвойстваБлокировкиСеансовИЗаданий) Экспорт
		
	УстанавливаемаяБлокировка = ОбщегоНазначения.СкопироватьРекурсивно(СвойстваБлокировкиСеансовИЗаданий, Ложь);
	ПустаяДата = Дата(1, 1, 1);
	УстановитьУмолчание(УстанавливаемаяБлокировка.ДатаС, ПустаяДата);
	УстановитьУмолчание(УстанавливаемаяБлокировка.ДатаПо, ПустаяДата);

	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);		
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);

	УстановитьСвойство(БазаКластера.ВключенаБлокировкаНачалаСеансов, УстанавливаемаяБлокировка, "БлокировкаСеансов");
	УстановитьСвойство(БазаКластера.ВремяНачалаБлокировки, УстанавливаемаяБлокировка, "ДатаС");
	УстановитьСвойство(БазаКластера.ВремяОкончанияБлокировки, УстанавливаемаяБлокировка, "ДатаПо");
	УстановитьСвойство(БазаКластера.СообщениеБлокировки, УстанавливаемаяБлокировка, "Сообщение");
	УстановитьСвойство(БазаКластера.КодРазрешенияНачалаСеансов, УстанавливаемаяБлокировка, "КодРазрешения");
	УстановитьСвойство(БазаКластера.ПараметрБлокировки, УстанавливаемаяБлокировка, "ПараметрБлокировки");
	УстановитьСвойство(БазаКластера.БлокировкаРегламентныхЗаданий, УстанавливаемаяБлокировка, "БлокировкаРегламентныхЗаданий");	
	
	БазаКластера.Записать();
КонецПроцедуры

// См. АдминистрированиеКластера.ПроверитьПараметрыАдминистрирования
Процедура ПроверитьПараметрыАдминистрирования(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ = Неопределено,
	ПроверятьПараметрыАдминистрированияИнформационнойБазы = Истина,
	ПроверятьПараметрыАдминистрированияКластера = Истина) Экспорт
	
	Если ПроверятьПараметрыАдминистрированияКластера ИЛИ ПроверятьПараметрыАдминистрированияИнформационнойБазы Тогда
		АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
		КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);		
	КонецЕсли;
	Если ПроверятьПараметрыАдминистрированияИнформационнойБазы Тогда
		БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	КонецЕсли;	
КонецПроцедуры

#КонецОбласти

#Область БлокировкаРегламентныхЗаданий

// См. АдминистрированиеКластера.БлокировкаРегламентныхЗаданийИнформационнойБазы
Функция БлокировкаРегламентныхЗаданийИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ) Экспорт	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);		
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	Возврат БазаКластера.БлокировкаРегламентныхЗаданий;
КонецФункции

// См. АдминистрированиеКластера.УстановитьБлокировкуРегламентныхЗаданийИнформационнойБазы
Процедура УстановитьБлокировкуРегламентныхЗаданийИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач БлокировкаРегламентныхЗаданий) Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	Если БазаКластера.БлокировкаРегламентныхЗаданий <> БлокировкаРегламентныхЗаданий Тогда
		БазаКластера.БлокировкаРегламентныхЗаданий = БлокировкаРегламентныхЗаданий;
		БазаКластера.Записать();
	КонецЕсли;
КонецПроцедуры

#КонецОбласти

#Область СеансыИнформационнойБазы

// См. АдминистрированиеКластера.СеансыИнформационнойБазы
Функция СеансыИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач Фильтр = Неопределено) Экспорт
	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	
	ИдентификаторыКлиентскихПриложений = АдминистрированиеКластера.ИдентификаторыКлиентскихПриложений();		
	АдминистрированиеКластера.ДобавитьУсловиеФильтра(Фильтр, "ИдентификаторКлиентскогоПриложения", ВидСравнения.ВСписке, ИдентификаторыКлиентскихПриложений);
	
	Результат = СписокСеансов(АгентСервера, КластерСервера, БазаКластера, Фильтр);
	Возврат Результат;

КонецФункции

// См. АдминистрированиеКластера.УдалитьСеансыИнформационнойБазы
Процедура УдалитьСеансыИнформационнойБазы(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач Фильтр = Неопределено) Экспорт
	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	
	СообщениеПользователям = НСтр("ru = 'Сеанс завершен администратором'");
	
	КоличествоПопыток = 4;
	ВсеСеансыЗавершены = Ложь;
	ОтметкиЗавершения = Новый Соответствие();
	БылиОшибки = Ложь;
	Для ТекущаяПопытка = 1 По КоличествоПопыток Цикл
		СписокСеансов = СписокСеансов(АгентСервера, КластерСервера, БазаКластера, Фильтр, Истина);
		Если НЕ ЗначениеЗаполнено(СписокСеансов) Тогда
			ВсеСеансыЗавершены = Истина;
			Прервать;
		КонецЕсли;
		Для Каждого Сеанс Из СписокСеансов Цикл
			Попытка
				ОбъектСеанса = Сеанс.ОбъектСеанса; // АдминистрированиеСеанс
				НомерСеанса = ОбъектСеанса.НомерСеанса;
				ЕстьОтметкаЗавершения = ОтметкиЗавершения.Получить(ОбъектСеанса.ИдентификаторСеанса) = Истина;
				Если НЕ ЕстьОтметкаЗавершения Тогда
					ОбъектСеанса.ЗавершитьСеанс(СообщениеПользователям);
					ОтметкиЗавершения.Вставить(ОбъектСеанса.ИдентификаторСеанса, Истина);
				КонецЕсли;
			Исключение
				ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Ошибка завершения сеанса %1: %2'"),
					НомерСеанса, ОписаниеОшибки);
				ЗаписатьОшибкуВЖурналРегистрации(Комментарий);
				БылиОшибки = Истина;
				Продолжить;
			КонецПопытки;
		КонецЦикла;
		
		ЭтоПромежуточнаяПопытка = ТекущаяПопытка > 1 И ТекущаяПопытка < КоличествоПопыток;
		Если ЭтоПромежуточнаяПопытка Тогда
			Пауза(ТекущаяПопытка);
		КонецЕсли;
	КонецЦикла;	
	
	Если Не ВсеСеансыЗавершены Тогда
		Если БылиОшибки Тогда
			ТекстИсключения = НСтр("ru = 'Не удалось завершить сеансы. См. журнал регистрации.'");
		Иначе
			ТекстИсключения = НСтр("ru = 'Не удалось завершить сеансы.'");
		КонецЕсли;
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область СоединенияСИнформационнойБазой

// См. АдминистрированиеКластера.СоединенияСИнформационнойБазой
Функция СоединенияСИнформационнойБазой(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач Фильтр = Неопределено) Экспорт
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	Результат = СписокСоединений(АгентСервера, КластерСервера, БазаКластера, Фильтр);
	Возврат Результат;
КонецФункции

// См. АдминистрированиеКластера.РазорватьСоединенияСИнформационнойБазой
Процедура РазорватьСоединенияСИнформационнойБазой(Знач ПараметрыАдминистрированияКластера, Знач ПараметрыАдминистрированияИБ, Знач Фильтр = Неопределено) Экспорт
	
	АгентСервера = АгентСервера(ПараметрыАдминистрированияКластера);	
	КластерСервера = КластерСервера(АгентСервера, ПараметрыАдминистрированияКластера);
	БазаКластера = БазаКластера(КластерСервера, ПараметрыАдминистрированияИБ);
	
	ИдентификаторыКлиентскихПриложений = АдминистрированиеКластера.ИдентификаторыКлиентскихПриложений();
	АдминистрированиеКластера.ДобавитьУсловиеФильтра(Фильтр, "ИмяПриложения", ВидСравнения.ВСписке, ИдентификаторыКлиентскихПриложений);
		
	КоличествоПопыток = 4;
	ВсеСоединенияРазорваны = Ложь;
	ОтметкиОтключения = Новый Соответствие();
	БылиОшибки = Ложь;
	Для ТекущаяПопытка = 1 По КоличествоПопыток Цикл
		СписокСоединений = СписокСоединений(АгентСервера, КластерСервера, БазаКластера, Фильтр, Ложь); // Массив Из АдминистрированиеСоединение 
		Если НЕ ЗначениеЗаполнено(СписокСоединений) Тогда
			ВсеСоединенияРазорваны = Истина;
			Прервать;
		КонецЕсли;

		Для Каждого Соединение Из СписокСоединений Цикл
			Попытка
				НомерСоединения = Соединение.НомерСоединения;
				ЕстьОтметкаОтключения = ОтметкиОтключения.Получить(Соединение.ИдентификаторСоединения) = Истина;
				Если НЕ ЕстьОтметкаОтключения Тогда
					Соединение.Отключить();
					ОтметкиОтключения.Вставить(Соединение.ИдентификаторСоединения, Истина);
				КонецЕсли;
			Исключение
				ОписаниеОшибки = ОбработкаОшибок.ПодробноеПредставлениеОшибки(ИнформацияОбОшибке());
				Комментарий = СтроковыеФункцииКлиентСервер.ПодставитьПараметрыВСтроку(НСтр("ru = 'Ошибка отключения соединения %1: %2'"),
					НомерСоединения, ОписаниеОшибки);
				ЗаписатьОшибкуВЖурналРегистрации(Комментарий);
				БылиОшибки = Истина;
				Продолжить;
			КонецПопытки;
		КонецЦикла;
		
		ЭтоПромежуточнаяПопытка = ТекущаяПопытка > 1 И ТекущаяПопытка < КоличествоПопыток;
		Если ЭтоПромежуточнаяПопытка Тогда
			Пауза(ТекущаяПопытка);
		КонецЕсли;
	КонецЦикла;
	
	Если Не ВсеСоединенияРазорваны Тогда
		Если БылиОшибки Тогда
			ТекстИсключения = НСтр("ru = 'Не удалось разорвать соединения. См. журнал регистрации.'");
		Иначе
			ТекстИсключения = НСтр("ru = 'Не удалось разорвать соединения.'");
		КонецЕсли;
		ВызватьИсключение ТекстИсключения;
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

