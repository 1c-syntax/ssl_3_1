Функция СвойстваБлокировкиСеансовИРегламентныхЗаданий(БазаКластера)
	Результат = АдминистрированиеКластера.СвойстваБлокировкиСеансовИРегламентныхЗаданий();
	Результат.БлокировкаСеансов = БазаКластера.ВключенаБлокировкаНачалаСеансов;
	Результат.ДатаС = БазаКластера.ВремяНачалаБлокировки;
	Результат.ДатаПо = БазаКластера.ВремяОкончанияБлокировки;
	Результат.Сообщение = БазаКластера.СообщениеБлокировки;
	Результат.КодРазрешения = БазаКластера.КодРазрешенияНачалаСеансов;
	Результат.ПараметрБлокировки = БазаКластера.ПараметрБлокировки;
	Результат.БлокировкаРегламентныхЗаданий = БазаКластера.БлокировкаРегламентныхЗаданий;
	Возврат Результат;
КонецФункции

Функция ОписаниеРабочегоПроцесса(РабочийПроцесс, КластерСервера)
	
	Результат = АдминистрированиеКластера.СвойстваРабочегоПроцесса();
	ЗаполнитьЗначенияСвойств(Результат, РабочийПроцесс);

	Результат.РеакцияСервера = Окр(РабочийПроцесс.СредняяДлительностьВызова, 3);
	Результат.ЗатраченоСУБД = Окр(РабочийПроцесс.СредняяДлительностьВызововСУБД, 3);
	Результат.ЗатраченоМенеджеромБлокировок = Окр(РабочийПроцесс.СредняяДлительностьВызововСервисов, 3);
	Результат.ЗатраченоСервером = Окр(РабочийПроцесс.СредняяДлительностьОбработкиВызоваРабочимПроцессом, 3);
	Результат.КлиентскихПотоков = Окр(РабочийПроцесс.СреднееКоличествоПотоков, 3);
	Результат.ПревышениеНадКритическимЗначением = РабочийПроцесс.ВремяПревышенияПоПамяти;
	Результат.ЗанятоПамяти = РабочийПроцесс.ПотреблениеПамяти / 1024;
	Результат.Идентификатор = РабочийПроцесс.ИдентификаторПроцесса;
	Результат.Запущен = ?(РабочийПроцесс.Активен, 1, 0);
	Результат.МоментЗапуска = РабочийПроцесс.ВремяЗапуска;
	Результат.Соединений = КластерСервера.ПолучитьСоединения().Количество();
	
	Если РабочийПроцесс.СостояниеРабочегоПроцесса = АдминистрированиеСостояниеРабочегоПроцесса.НеИспользуется Тогда
		Результат.Использование = 0;
	ИначеЕсли РабочийПроцесс.СостояниеРабочегоПроцесса = АдминистрированиеСостояниеРабочегоПроцесса.Используется Тогда
		Результат.Использование = 1;
	ИначеЕсли РабочийПроцесс.СостояниеРабочегоПроцесса = АдминистрированиеСостояниеРабочегоПроцесса.Резервный Тогда
		Результат.Использование = 2;		
	КонецЕсли;
	
	Если ЗначениеЗаполнено(РабочийПроцесс.Лицензии) Тогда
		Результат.Лицензия = ОписаниеЛицензии(РабочийПроцесс.Лицензии[0]);
	КонецЕсли;
	
	Возврат Результат;
	
КонецФункции

Функция ОписаниеСоединения(Соединение)
